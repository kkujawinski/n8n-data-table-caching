{
  "name": "n8n-nodes-datatable-cache",
  "version": "0.1.2",
  "description": "Read-through / write-back cache node backed by an n8n data table",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "cache",
    "data-table",
    "datatable"
  ],
  "license": "MIT",
  "homepage": "https://github.com/kamilkujawinski/n8n-nodes-datatable-cache",
  "author": {
    "name": "Kamil Kujawinski",
    "email": "kamil@kujawin.ski"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kamilkujawinski/n8n-nodes-datatable-cache.git"
  },
  "engines": {
    "node": ">=20.15"
  },
  "main": "index.js",
  "scripts": {
    "build": "rimraf dist && tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes --write",
    "lint": "eslint nodes package.json",
    "lintfix": "eslint nodes package.json --fix",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build && npm run lint"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "nodes": [
      "dist/nodes/DataTableCache/DataTableCache.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^8.57.1",
    "eslint-plugin-n8n-nodes-base": "^1.16.7",
    "gulp": "^5.0.0",
    "n8n-workflow": "^2.16.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2"
  }
}
